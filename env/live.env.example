## Copy to env/live.env (gitignored). Live app on server uses DB_HOST=127.0.0.1.
## From your Mac: start SSH tunnel first, then npm run dev:live
## Set DB_PROTECTED=1 so seed/DROP scripts never run.

NODE_ENV=development
PORT=7020
HOST=127.0.0.1

JET_LOGGER_MODE=CONSOLE
JET_LOGGER_FILEPATH=jet-logger.log
JET_LOGGER_TIMESTAMP=TRUE
JET_LOGGER_FORMAT=LINE

COOKIE_DOMAIN=localhost
COOKIE_PATH=/
SECURE_COOKIE=false
JWT_SECRET=
COOKIE_SECRET=
COOKIE_EXP=259200000

DB_HOST=127.0.0.1
DB_USER=
PASSWORD=
DATABASE=practitionermaindb
DB_PROTECTED=1

STRIPE_SECRET_KEY=
GOOGLE_MAPS_API_KEY=
JOB_ASSIGN_AUTHORIZED_EMAILS=
ADMIN_NOTIFICATIONS_CC=
# Home visit booking notifications (comma-separated). Defaults to homevisits@youth-revisited.co.uk
HOME_VISIT_NOTIFICATIONS_TO=homevisits@youth-revisited.co.uk

# GHL WhatsApp on new Home Visit booking (same tags as site PHP)
GHL_KEY=
GHL_LOCATION_ID=
GHL_HOME_VISIT_NOTIFY_ENABLED=1
# Mo / sales contact (defaults match current site sales-loop PHP if unset)
GHL_HOME_VISIT_SALES_NAME=Osama
GHL_HOME_VISIT_SALES_PHONE=+201224622995
GHL_HOME_VISIT_SALES_EMAIL=mohamed.ossama.831@gmail.com

# Partner / affiliate portal SSO (phleb app → WordPress partner-login)
PARTNER_LOGIN_URL=https://www.youth-revisited.co.uk/partner-login/
PARTNER_SIGNUP_URL=https://www.youth-revisited.co.uk/partner-register/
PARTNER_WP_API_URL=https://www.youth-revisited.co.uk/wp-json/yr/v1
PARTNER_SSO_SECRET=
